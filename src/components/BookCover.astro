---
interface Props {
  src: string;
  title?: string;
  author?: string;
  href?: string;
}
const { src, title, author, href } = Astro.props;
---

<figure class="book-cover">
  {href ? (
    <a href={href} target="_blank" rel="noopener noreferrer">
      <img src={src} alt={title ?? 'Book cover'} />
    </a>
  ) : (
    <img src={src} alt={title ?? 'Book cover'} />
  )}
  {(title || author) && (
    <figcaption>
      {title && <span class="book-title">{title}</span>}
      {author && <span class="book-author">{author}</span>}
    </figcaption>
  )}
</figure>

<style>
  .book-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    transform-origin: bottom center;
    transition: transform 0.25s cubic-bezier(0.34, 1.4, 0.64, 1);
    cursor: pointer;
    padding-bottom: 1rem;
  }

  .book-cover:hover {
    transform: translateY(-1rem) rotate(-2deg) scale(1.05);
  }

  .book-cover img {
    display: block;
    height: clamp(160px, 28vh, 280px);
    width: auto;
    max-width: clamp(110px, 18vw, 200px);
    object-fit: cover;
    box-shadow:
      4px 4px 10px rgba(0,0,0,0.22),
      2px 2px 4px rgba(0,0,0,0.12),
      -1px 0 3px rgba(0,0,0,0.08);
    border-radius: 2px;
  }

  .book-cover a {
    display: block;
    text-decoration: none;
  }

  figcaption {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
    max-width: clamp(110px, 18vw, 200px);
    text-align: center;
  }

  .book-title {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.3;
    display: block;
  }

  .book-author {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    opacity: 0.55;
    display: block;
  }
</style>
