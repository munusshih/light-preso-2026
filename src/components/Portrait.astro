---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  captionHref?: string;
}
const { src, alt = '', caption = '', captionHref } = Astro.props;
---

<figure class="portrait-frame">
  <img src={src} alt={alt} loading="lazy" />
  {caption && (
    <figcaption>
      {captionHref
        ? <a href={captionHref} target="_blank" rel="noopener noreferrer">{caption}</a>
        : caption}
    </figcaption>
  )}
</figure>

<style>
  .portrait-frame {
    display: inline-block;
    padding: 12px 12px 0;
    background: #fff;
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    margin-bottom: -5rem;
    z-index: 2;
    cursor: grab;
    will-change: transform;
    touch-action: none;
    user-select: none;
    transform-style: preserve-3d;
  }

  .portrait-frame:active { cursor: grabbing; }

  .portrait-frame.visible {
    animation: portrait-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes portrait-reveal {
    from { opacity: 0; transform: translateY(30px) rotate(-1.5deg); }
    to   { opacity: 1; transform: translateY(0)    rotate(-1.5deg); }
  }

  img {
    display: block;
    height: clamp(320px, 50vh, 520px);
    width: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    object-position: center top;
    pointer-events: none;
    position: relative;
    z-index: 1;
  }

  /* Holographic rainbow layer */
  .portrait-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        115deg,
        rgba(255,0,128,0.55)   0%,
        rgba(255,180,0,0.55)  16%,
        rgba(255,255,0,0.55)  33%,
        rgba(0,255,128,0.55)  50%,
        rgba(0,128,255,0.55)  66%,
        rgba(160,0,255,0.55)  83%,
        rgba(255,0,128,0.55) 100%
      );
    background-size: 200% 200%;
    background-position: var(--holo-x, 50%) var(--holo-y, 50%);
    mix-blend-mode: color-dodge;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease, background-position 0.08s linear;
    z-index: 2;
  }

  /* Specular glare */
  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 45% at var(--glare-x, 50%) var(--glare-y, 50%),
      rgba(255,255,255,0.55) 0%,
      rgba(255,255,255,0.12) 45%,
      transparent 70%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease, background 0.06s linear;
    z-index: 3;
  }

  .portrait-frame.shiny::before,
  .portrait-frame.shiny::after {
    opacity: 1;
  }

  figcaption {
    width: 0;
    min-width: 100%;
    padding: 0.55rem 0.25rem 0.65rem;
    font-family: 'Be Vietnam Pro', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    font-style: italic;
    color: #000;
    letter-spacing: 0.01em;
    text-align: left;
    line-height: 1.45;
    opacity: 0.55;
    overflow-wrap: break-word;
    position: relative;
    z-index: 1;
  }

  figcaption a {
    color: inherit;
    text-underline-offset: 0.2em;
  }
</style>

<script>
  for (const frame of document.querySelectorAll<HTMLElement>('.portrait-frame')) {
    let tx = 0, ty = 0, rot = -1.5;
    let startX = 0, startY = 0;
    let dragging = false;

    function applyTransform(extra = '') {
      frame.style.transform = `translate(${tx}px,${ty}px) ${extra} rotate(${rot}deg)`;
    }

    // Hand off from CSS animation to JS
    frame.addEventListener('animationend', () => {
      frame.style.opacity = '1';
      frame.style.animation = 'none';
      applyTransform();
    }, { once: true });

    // ── Drag ─────────────────────────────────────────────────────────────
    frame.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      dragging = true;
      frame.classList.remove('shiny');
      frame.setPointerCapture(e.pointerId);
      startX = e.clientX - tx;
      startY = e.clientY - ty;
      frame.style.transition = 'box-shadow 0.2s';
      frame.style.boxShadow = '0 22px 55px rgba(0,0,0,0.24)';
      frame.style.zIndex = '100';
      applyTransform('scale(1.05)');
    });

    frame.addEventListener('pointermove', (e) => {
      if (!frame.hasPointerCapture(e.pointerId)) return;
      tx = e.clientX - startX;
      ty = e.clientY - startY;
      applyTransform('scale(1.05)');
    });

    frame.addEventListener('pointerup', () => {
      dragging = false;
      rot = -8 + Math.random() * 16;
      frame.style.transition = 'transform 0.5s cubic-bezier(0.34,1.5,0.64,1), box-shadow 0.4s';
      frame.style.boxShadow = '0 4px 24px rgba(0,0,0,0.10)';
      applyTransform();
    });

    // ── Holographic shine ─────────────────────────────────────────────────
    frame.addEventListener('mousemove', (e) => {
      if (dragging) return;
      const rect = frame.getBoundingClientRect();
      const px = (e.clientX - rect.left) / rect.width;   // 0–1
      const py = (e.clientY - rect.top)  / rect.height;  // 0–1

      // 3D tilt: ±14° on each axis
      const ry =  (px - 0.5) * 28;
      const rx = -(py - 0.5) * 28;

      frame.style.transition = 'box-shadow 0.2s';
      frame.style.boxShadow = `${-ry * 0.5}px ${rx * 0.5 + 8}px 30px rgba(0,0,0,0.18)`;
      applyTransform(`perspective(700px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.03)`);

      // Rainbow gradient position shifts opposite to tilt for parallax feel
      frame.style.setProperty('--holo-x', `${(1 - px) * 120 - 10}%`);
      frame.style.setProperty('--holo-y', `${(1 - py) * 120 - 10}%`);
      frame.style.setProperty('--glare-x', `${px * 100}%`);
      frame.style.setProperty('--glare-y', `${py * 100}%`);
      frame.classList.add('shiny');
    });

    frame.addEventListener('mouseleave', () => {
      if (dragging) return;
      frame.classList.remove('shiny');
      frame.style.transition = 'transform 0.6s cubic-bezier(0.34,1.2,0.64,1), box-shadow 0.4s';
      frame.style.boxShadow = '0 4px 24px rgba(0,0,0,0.10)';
      applyTransform();
    });
  }
</script>
