---
interface Constellation {
  name: string;
  stars: [number, number][]; // 0..1 normalised positions
}
interface Props {
  constellations: Constellation[];
  caption?: string;
  /** density of background noise stars, default 60 */
  noise?: number;
  border?: boolean;
}
const {
  constellations,
  caption,
  noise = 60,
  border = false,
} = Astro.props;
const uid = `constellation-${Math.random().toString(36).slice(2, 9)}`;
const payload = JSON.stringify({ constellations, noise });
---

<figure class="diagram-figure constellation-figure">
  <div
    class={`diagram-canvas constellation-canvas${border ? " bordered" : ""}`}
    id={uid}
    data-constellation={payload}
  ></div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  import { loadP5, FONT_STACK, readThemeColors, readBodyFontPx } from "../lib/p5-loader";

  type Constellation = { name: string; stars: [number, number][] };

  function initConstellation(container: HTMLElement) {
    if (container.dataset.ready === "1") return;
    container.dataset.ready = "1";

    const { constellations, noise } = JSON.parse(
      container.dataset.constellation ?? "{}"
    ) as { constellations: Constellation[]; noise: number };

    new (window as any).p5((p: any) => {
      let W = 0;
      let H = 0;
      let ctx: CanvasRenderingContext2D;
      let theme = { paper: "#fbfaf5", ink: "#000000" };
      let bodyPx = 16;

      function refreshTheme() {
        theme = readThemeColors(container);
        bodyPx = readBodyFontPx(container);
      }

      function uiScale() {
        return Math.max(1, Math.min(W, H) / 420);
      }

      type NoiseStar = { x: number; y: number; size: number; phase: number; rate: number };
      let noiseStars: NoiseStar[] = [];

      function setFont(size: number, italic = true, align: "left" | "center" = "left") {
        ctx.font = `${italic ? "italic " : ""}${size}px ${FONT_STACK}`;
        ctx.textBaseline = "middle";
        ctx.textAlign = align;
      }

      function regenNoise() {
        noiseStars = [];
        for (let i = 0; i < noise; i++) {
          noiseStars.push({
            x: Math.random() * W,
            y: Math.random() * H,
            size: 0.8 + Math.random() * 1.6,
            phase: Math.random() * Math.PI * 2,
            rate: 0.3 + Math.random() * 0.8,
          });
        }
      }

      p.setup = () => {
        W = container.clientWidth;
        H = container.clientHeight;
        const canvas = p.createCanvas(W, H);
        canvas.parent(container);
        ctx = p.drawingContext as CanvasRenderingContext2D;
        refreshTheme();
        regenNoise();
        matchMedia("(prefers-color-scheme: dark)").addEventListener(
          "change",
          refreshTheme
        );
      };

      p.windowResized = () => {
        const nw = container.clientWidth;
        const nh = container.clientHeight;
        if (nw === W && nh === H) return;
        p.resizeCanvas(nw, nh);
        W = nw;
        H = nh;
        refreshTheme();
        regenNoise();
      };

      p.draw = () => {
        p.clear();
        const t = p.millis() / 1000;
        const s = uiScale();

        // noise stars — twinkle by size only
        p.noStroke();
        p.fill(theme.ink);
        noiseStars.forEach((s) => {
          const pulse = 0.5 + 0.5 * (Math.sin(t * s.rate + s.phase) * 0.5 + 0.5);
          p.ellipse(s.x, s.y, s.size * pulse);
        });

        // constellations
        constellations.forEach((c, ci) => {
          const drift = Math.sin(t * 0.15 + ci * 1.3) * 3;
          const points = c.stars.map(([nx, ny]) => ({
            x: nx * W + drift,
            y: ny * H + drift * 0.6,
          }));
          if (!points.length) return;

          // hairlines connecting in order
          p.stroke(theme.ink);
          p.strokeWeight(0.8 * s);
          p.noFill();
          for (let i = 0; i < points.length - 1; i++) {
            p.line(points[i].x, points[i].y, points[i + 1].x, points[i + 1].y);
          }

          // stars (filled dots)
          p.noStroke();
          p.fill(theme.ink);
          points.forEach((pt) => {
            p.ellipse(pt.x, pt.y, 4.8 * s);
          });

          // name near first star, offset
          const first = points[0];
          setFont(bodyPx, true, "left");
          ctx.fillStyle = theme.ink;
          ctx.fillText(c.name, first.x + bodyPx * 0.8, first.y - bodyPx * 0.9);
        });
      };
    });
  }

  loadP5().then(() => {
    document
      .querySelectorAll<HTMLElement>(".constellation-canvas")
      .forEach((el) => initConstellation(el));
  });
</script>
