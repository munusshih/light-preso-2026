---
// Container for TraitItem components.
---

<div class="trait-list">
  <slot />
</div>

<style>
  .trait-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    counter-reset: trait-counter;
  }

  /* CMYK accent cycling passed down via CSS custom property */
  .trait-list > :global(*:nth-child(4n+1)) { --accent: #00AEEF; }
  .trait-list > :global(*:nth-child(4n+2)) { --accent: #EC008C; }
  .trait-list > :global(*:nth-child(4n+3)) { --accent: #FFF200; }
  .trait-list > :global(*:nth-child(4n+0)) { --accent: #231F20; }

  /* Counter increments on each child */
  .trait-list > :global(*) { counter-increment: trait-counter; }

  /* Expose the counter value to TraitItem's .trait-num via ::before */
  .trait-list > :global(* .trait-num::before) {
    content: counter(trait-counter, decimal-leading-zero);
  }
</style>
