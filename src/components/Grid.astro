---
interface Props {
  cols?: number;
  gap?: string;
}
const { cols = 2, gap = '1.5rem' } = Astro.props;
---

<div class="layout-grid" style={`--cols: ${cols}; --gap: ${gap}`}>
  <slot />
</div>

<style>
  .layout-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap);
    justify-content: center;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
</style>
