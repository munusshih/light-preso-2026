---
interface Props {
  gap?: string;
  align?: 'left' | 'center' | 'right';
}
const { gap = '2rem', align = 'center' } = Astro.props;
---

<div class="layout-column" style={`--gap: ${gap}; --align: ${align}`}>
  <slot />
</div>

<style>
  .layout-column {
    display: flex;
    flex-direction: column;
    align-items: var(--align);
    gap: var(--gap);
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
</style>
