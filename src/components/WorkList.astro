---
// Uses a section > ul so global `body > ul` padding-block doesn't apply.
---

<section class="work-list">
  <ul>
    <slot />
  </ul>
</section>

<style>
  .work-list {
    width: 100%;
    padding: 5rem clamp(2rem, 6vw, 8rem) 7rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }
</style>
