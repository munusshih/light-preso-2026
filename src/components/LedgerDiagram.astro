---
/**
 * Double-entry ledger. Two columns (debits / credits, or any binary pairing
 * the data implies) with paired entries balancing across the spread.
 * Reads like a page from an account book — typographic, ruled, with a
 * tally at the bottom.
 */
interface Entry {
  /** date / period column on the far left */
  when?: string;
  /** label on the debit side */
  debit?: string;
  /** label on the credit side */
  credit?: string;
  /** italic gloss under the entry */
  gloss?: string;
}
interface Props {
  /** column heads */
  debitHead?: string;
  creditHead?: string;
  /** title above the ledger */
  title?: string;
  entries: Entry[];
  /** optional tally / sum line */
  tally?: { debit: string; credit: string };
  caption?: string;
}
const {
  debitHead = "received",
  creditHead = "given",
  title,
  entries,
  tally,
  caption,
} = Astro.props;
---

<figure class="diagram-figure ledger-figure">
  <div class="ledger-canvas">
    {title && <p class="ledger-title">{title}</p>}
    <table class="ledger-table">
      <thead>
        <tr>
          <th class="when-col">date</th>
          <th class="side-col">{debitHead}</th>
          <th class="folio-col">/</th>
          <th class="side-col">{creditHead}</th>
        </tr>
      </thead>
      <tbody>
        {entries.map((e, i) => (
          <>
            <tr class="entry-row">
              <td class="when-col">{e.when ?? ""}</td>
              <td class="side-col debit">{e.debit ?? <span class="empty">—</span>}</td>
              <td class="folio-col">{String(i + 1).padStart(2, "0")}</td>
              <td class="side-col credit">{e.credit ?? <span class="empty">—</span>}</td>
            </tr>
            {e.gloss && (
              <tr class="gloss-row">
                <td></td>
                <td colspan="3" class="gloss-cell">{e.gloss}</td>
              </tr>
            )}
          </>
        ))}
      </tbody>
      {tally && (
        <tfoot>
          <tr>
            <td class="when-col"></td>
            <td class="side-col tally">{tally.debit}</td>
            <td class="folio-col">∑</td>
            <td class="side-col tally">{tally.credit}</td>
          </tr>
        </tfoot>
      )}
    </table>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .ledger-canvas {
    color: var(--ink, #000);
    font-family: "Source Serif 4", "Times New Roman", Times, serif;
    padding: 1.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ledger-title {
    font-family: "Source Code Pro", monospace;
    font-size: 0.72em !important;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0 !important;
    padding: 0;
    text-align: center;
  }
  .ledger-table {
    border-collapse: collapse;
    width: 100%;
    background: transparent;
  }
  .ledger-table th,
  .ledger-table td {
    border-top: 1px solid var(--ink, #000);
    padding: 0.55em 0.8em;
    vertical-align: baseline;
    font-size: 0.95em;
    line-height: 1.45;
  }
  .ledger-table thead th {
    border-bottom: 2px solid var(--ink, #000);
    border-top: 2px solid var(--ink, #000);
    font-family: "Source Code Pro", monospace;
    font-size: 0.65em;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.65;
    font-weight: 500;
  }
  .when-col {
    width: 14%;
    font-family: "Source Code Pro", monospace;
    font-size: 0.78em;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }
  .side-col {
    width: 38%;
    font-style: italic;
  }
  .side-col.debit { border-right: 1px solid var(--ink, #000); }
  .folio-col {
    width: 10%;
    text-align: center;
    font-family: "Source Code Pro", monospace;
    font-size: 0.7em;
    opacity: 0.45;
    border-right: 1px solid var(--ink, #000);
  }
  .gloss-row td.gloss-cell {
    font-style: italic;
    font-size: 0.82em;
    opacity: 0.6;
    border-top: none;
    padding-top: 0;
    padding-bottom: 0.4em;
  }
  .empty { opacity: 0.3; }
  tfoot .tally {
    font-weight: 600;
    font-style: normal;
    font-variant: small-caps;
    border-top: 2px solid var(--ink, #000);
    border-bottom: 2px solid var(--ink, #000);
  }
  tfoot .when-col,
  tfoot .folio-col {
    border-top: 2px solid var(--ink, #000);
    border-bottom: 2px solid var(--ink, #000);
  }
  @media (max-width: 600px) {
    .ledger-table th,
    .ledger-table td { padding: 0.4em 0.4em; font-size: 0.85em; }
    .when-col { font-size: 0.7em; }
  }
</style>
