---
/**
 * Cross-tabulation matrix. Diagonal cells contain the concept name (axis);
 * off-diagonal cells contain the intersection label between row × col concepts.
 * Symmetric — pair "[i,j]" matches both (i,j) and (j,i).
 */
interface Concept {
  label: string;
}
interface Pair {
  idx: [number, number];
  label: string;
}
interface Props {
  concepts: Concept[];
  pairs?: Pair[];
  triple?: string;
  caption?: string;
}
const { concepts, pairs = [], triple, caption } = Astro.props;

function pairLabel(i: number, j: number): string {
  const found = pairs.find(
    (p) =>
      (p.idx[0] === i && p.idx[1] === j) ||
      (p.idx[0] === j && p.idx[1] === i)
  );
  return found?.label ?? "";
}
---

<figure class="diagram-figure matrix-figure">
  <div class="matrix-canvas">
    <table class="matrix-table">
      <thead>
        <tr>
          <th></th>
          {concepts.map((c) => <th>{c.label}</th>)}
        </tr>
      </thead>
      <tbody>
        {concepts.map((row, i) => (
          <tr>
            <th>{row.label}</th>
            {concepts.map((_, j) => (
              <td class={i === j ? "diag" : "cross"}>
                {i === j ? <span class="rule">———</span> : <span>{pairLabel(i, j)}</span>}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
    {triple && (
      <div class="matrix-triple">
        <span class="brace">{`{`}</span>
        <span class="triple-label">all three : {triple}</span>
        <span class="brace">{`}`}</span>
      </div>
    )}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .matrix-canvas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 1rem;
  }
  .matrix-table {
    border-collapse: collapse;
    font-family: "Source Serif 4", "Times New Roman", Times, serif;
    color: var(--ink, #000);
    background: transparent;
  }
  .matrix-table th,
  .matrix-table td {
    border: 1px solid var(--ink, #000);
    padding: 0.6em 0.85em;
    min-width: 7em;
    text-align: center;
    vertical-align: middle;
    line-height: 1.3;
  }
  .matrix-table thead th,
  .matrix-table tbody th {
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    text-transform: lowercase;
    font-variant: small-caps;
  }
  .matrix-table thead th:first-child {
    border-top: none;
    border-left: none;
  }
  .matrix-table tbody th {
    text-align: right;
  }
  .matrix-table td.diag {
    background: transparent;
  }
  .matrix-table td.diag .rule {
    opacity: 0.35;
    letter-spacing: 0.1em;
  }
  .matrix-table td.cross {
    font-style: italic;
  }
  .matrix-triple {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    font-family: "Source Serif 4", "Times New Roman", Times, serif;
    font-style: italic;
    color: var(--ink, #000);
    opacity: 0.85;
  }
  .matrix-triple .brace {
    font-size: 2.4em;
    line-height: 0.5;
    font-style: normal;
    opacity: 0.5;
  }
  @media (max-width: 600px) {
    .matrix-table th,
    .matrix-table td {
      padding: 0.4em 0.5em;
      min-width: 5em;
      font-size: 0.85em;
    }
  }
</style>
