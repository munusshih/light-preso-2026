---
// Horizontal scrollable bookshelf. Place BookCover components inside.
---

<div class="book-shelf-outer">
  <div class="book-shelf">
    <slot />
  </div>
</div>

<style>
  .book-shelf-outer {
    width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .book-shelf-outer::-webkit-scrollbar { display: none; }

  .book-shelf {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    padding: 3rem clamp(2rem, 6vw, 8rem) 0;
    min-width: max-content;
    border-bottom: 3px solid #000;
    position: relative;
  }

  /* Slight shadow below the shelf line */
  .book-shelf::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    right: 0;
    height: 8px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.08), transparent);
    pointer-events: none;
  }
</style>
