---
interface Props {
  color?: string;
  textColor?: string;
}
const { color, textColor } = Astro.props;
---

<span
  class="magnet"
  style={color ? `--bg:${color};--fg:${textColor ?? '#000'}` : ''}
>
  <slot />
</span>

<style>
  .magnet {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.3em 0.7em;
    background: var(--bg, #FFF200);
    color: var(--fg, #000);
    font-family: 'Be Vietnam Pro', sans-serif;
    font-weight: 800;
    font-size: clamp(1rem, 2.5vw, 1.6rem);
    letter-spacing: -0.01em;
    border-radius: 3px;
    box-shadow:
      0 2px 0 rgba(0,0,0,0.18),
      0 4px 14px rgba(0,0,0,0.22),
      inset 0 1px 0 rgba(255,255,255,0.35);
    transform: rotate(var(--r, 0deg));
    cursor: default;
    transition: transform 0.2s cubic-bezier(0.34, 1.6, 0.64, 1), box-shadow 0.2s;
    white-space: nowrap;
    position: relative;
  }

  .magnet:hover {
    transform: rotate(0deg) scale(1.14);
    box-shadow:
      0 4px 0 rgba(0,0,0,0.14),
      0 14px 30px rgba(0,0,0,0.28),
      inset 0 1px 0 rgba(255,255,255,0.35);
    z-index: 2;
  }
</style>
