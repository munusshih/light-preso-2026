---
interface Props {
  n: number | string;
  color?: 'cyan' | 'magenta' | 'yellow' | 'black' | 'pink' | 'green';
  size?: 'sm' | 'md' | 'lg';
}
const { n, color = 'yellow', size = 'md' } = Astro.props;

const bg: Record<string, string> = {
  cyan:    '#00AEEF',
  magenta: '#EC008C',
  yellow:  '#FFF200',
  black:   '#231F20',
  pink:    '#FFB3C6',
  green:   '#B8F2B1',
};
const fg: Record<string, string> = {
  cyan:    '#000',
  magenta: '#fff',
  yellow:  '#000',
  black:   '#fff',
  pink:    '#000',
  green:   '#000',
};

const sz: Record<string, string> = { sm: '2rem', md: '3rem', lg: '4.5rem' };
const fs: Record<string, string> = { sm: '0.9rem', md: '1.3rem', lg: '2rem' };

const bgColor  = bg[color]  ?? bg.yellow;
const fgColor  = fg[color]  ?? '#000';
const diameter = sz[size]   ?? sz.md;
const fontSize = fs[size]   ?? fs.md;
---

<span
  class="sticker"
  style={`--bg:${bgColor};--fg:${fgColor};--d:${diameter};--fs:${fontSize}`}
  aria-label={`number ${n}`}
>{n}</span>

<style>
  .sticker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--d);
    height: var(--d);
    background: var(--bg);
    color: var(--fg);
    font-family: 'Be Vietnam Pro', system-ui, sans-serif;
    font-size: var(--fs);
    font-weight: 800;
    line-height: 1;
    /* organic blob shape — hand-cut feel */
    border-radius: 47% 53% 44% 56% / 52% 46% 54% 48%;
    transform: rotate(-6deg);
    vertical-align: middle;
    margin: 0 0.2em;
    flex-shrink: 0;
    position: relative;
    top: -0.05em;
    /* subtle inner shadow to give it dimension */
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.12);
    letter-spacing: -0.02em;
    transition: transform 0.3s cubic-bezier(0.34, 1.6, 0.64, 1);
    cursor: default;
  }

  .sticker:hover {
    transform: rotate(6deg) scale(1.15);
  }
</style>
