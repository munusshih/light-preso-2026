---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="trait-item">
  <div class="trait-header">
    <span class="trait-num"></span>
    <h2 class="trait-title">{title}</h2>
    <div class="trait-body">
      <slot />
    </div>
  </div>

  <div class="trait-media">
    <slot name="images" />
  </div>
</div>

<style>
  .trait-item {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    background: #fff;
  }

  /* Header: number + title + description — takes remaining space */
  .trait-header {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 4rem clamp(2rem, 6vw, 8rem) 3rem;
    gap: 1.25rem;
  }

  /* Giant CMYK number — h1 scale */
  .trait-num {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: clamp(8rem, 22vw, 22rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.85;
    color: var(--accent, #00AEEF);
    display: block;
    margin-bottom: 1rem;
  }

  .trait-title {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: clamp(2rem, 4.5vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
    padding: 0;
    color: #000;
  }

  .trait-body {
    font-size: clamp(0.82rem, 1.3vw, 1rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.75;
    opacity: 0.55;
    max-width: 52ch;
  }

  .trait-body :global(p) { margin: 0; }

  /* Image panel — full-bleed strip at the bottom */
  .trait-media {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    gap: 2px;
    flex-shrink: 0;
  }
  .trait-media:empty { display: none; }
  .trait-media::-webkit-scrollbar { display: none; }

  .trait-media :global(img),
  .trait-media :global(video) {
    display: block;
    height: clamp(200px, 35vh, 420px);
    width: auto;
    flex-shrink: 0;
    object-fit: cover;
  }

  /* Single image: full width */
  .trait-media :global(img:only-child),
  .trait-media :global(video:only-child) {
    width: 100%;
    height: clamp(200px, 40vh, 500px);
  }
</style>
