---
interface Props {
  name: string;
  href?: string;
}
const { name, href } = Astro.props;
---

<li class="work-item">
  {href
    ? <a class="work-item-name" href={href} target="_blank" rel="noopener">{name}</a>
    : <span class="work-item-name">{name}</span>
  }
  <slot />
</li>

<style>
  .work-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    text-align: center;
    /* font-size, opacity, transition come from global ul > li rules */
  }

  .work-item-name {
    line-height: 1;
    text-decoration: none;
  }

  a.work-item-name:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
</style>
